{
  "version": 3,
  "overrides": {
    "our-works/index.html": {
      "path": "our-works"
    },
    "contact-us/index.html": {
      "path": "contact-us"
    },
    "about-us/index.html": {
      "path": "about-us"
    },
    "services/index.html": {
      "path": "services"
    },
    "index.html": {
      "path": ""
    }
  },
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "Content-Type": "application/xml"
      },
      "src": "/api/sitemap.xml"
    },
    {
      "headers": {
        "Content-Type": "text/plain"
      },
      "src": "/api/robots.txt"
    },
    {
      "headers": {
        "Content-Type": "application/xml"
      },
      "src": "/api/rss.xml"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "X-Robots-Tag": "index, follow",
        "Cache-Control": "public, max-age=3600, stale-while-revalidate=86400"
      },
      "src": "/"
    },
    {
      "headers": {
        "X-Robots-Tag": "index, follow",
        "Cache-Control": "public, max-age=300, stale-while-revalidate=3600"
      },
      "src": "/blogs"
    },
    {
      "headers": {
        "X-Robots-Tag": "index, follow",
        "Cache-Control": "public, max-age=600, stale-while-revalidate=3600"
      },
      "src": "/blogs/(.*)"
    },
    {
      "headers": {
        "X-Robots-Tag": "index, follow"
      },
      "src": "/about-us"
    },
    {
      "headers": {
        "X-Robots-Tag": "index, follow"
      },
      "src": "/services"
    },
    {
      "headers": {
        "X-Robots-Tag": "index, follow"
      },
      "src": "/our-works"
    },
    {
      "headers": {
        "X-Robots-Tag": "index, follow"
      },
      "src": "/contact-us"
    },
    {
      "headers": {
        "X-Robots-Tag": "noindex, nofollow"
      },
      "src": "/admin/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable",
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "src": "/_ipx/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<url>/)",
      "dest": "/index-isr?url=$url"
    },
    {
      "src": "(?<url>/__nuxt_error)",
      "dest": "/__fallback"
    },
    {
      "src": "(?<url>/blogs)",
      "dest": "/blogs-isr?url=$url"
    },
    {
      "src": "(?<url>/blogs/(?:.*))",
      "dest": "/blogs/[...]-isr?url=$url"
    },
    {
      "src": "(?<url>/about-us)",
      "dest": "/about-us-isr?url=$url"
    },
    {
      "src": "(?<url>/services)",
      "dest": "/services-isr?url=$url"
    },
    {
      "src": "(?<url>/our-works)",
      "dest": "/our-works-isr?url=$url"
    },
    {
      "src": "(?<url>/contact-us)",
      "dest": "/contact-us-isr?url=$url"
    },
    {
      "src": "/(.*)",
      "dest": "/__fallback"
    }
  ]
}